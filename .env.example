# Kalshi API credentials (required for live trading, optional for data)
KALSHI_API_KEY=your_kalshi_api_key_here
KALSHI_API_SECRET=your_kalshi_api_secret_here

# Polymarket (no key needed for read-only data)
# Optional: add your private key for live execution
POLY_PRIVATE_KEY=

# Strategy config
MIN_ARBI_SPREAD=0.03
MIN_BOND_PROBABILITY=0.92
MIN_BOND_ANNUALIZED_YIELD=0.50
